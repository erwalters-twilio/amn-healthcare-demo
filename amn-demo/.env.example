# Segment Write Key (Client-Side)
# Get your write key from: https://app.segment.com/<workspace>/sources/<source>/settings/keys
VITE_SEGMENT_WRITE_KEY=your_segment_write_key_here

# ============================================
# Server-Side Environment Variables
# These are only accessible in /api functions
# ============================================

# Twilio Configuration
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Segment Server-Side Write Key
# Get from: Segment Source Settings > API Keys
# NOTE: This should be DIFFERENT from the client-side key above
SEGMENT_WRITE_KEY=your_segment_server_side_write_key_here
