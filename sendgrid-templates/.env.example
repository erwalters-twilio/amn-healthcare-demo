# SendGrid Configuration
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dynamic Template ID from SendGrid Console
# Format: d-xxxxxxxxxxxxxxxxxxxxx
SENDGRID_PLACEMENT_TEMPLATE_ID=d-xxxxxxxxxxxxxxxxxxxxx

# Verified Sender Email (must be authenticated in SendGrid)
SENDGRID_FROM_EMAIL=placements@amnhealthcare.com

# Sender Name (displayed to recipients)
SENDGRID_FROM_NAME=AMN Healthcare

# Test Email Address (for testing)
TEST_EMAIL=your-test-email@example.com

# Optional: Segment Configuration (if using Segment integration)
SEGMENT_WRITE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SEGMENT_SPACE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
