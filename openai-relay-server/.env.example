# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-...

# Segment Profile API Token (get from Segment → Settings → Access Management → Tokens)
SEGMENT_PROFILE_TOKEN=sgp_...

# Segment Space ID (get from Segment → Settings → General Settings)
# Looks like: spa_xxxxxxxxxxxxx
SEGMENT_SPACE_ID=spa_xxxxxxxxxxxxx

# Server Port (default: 8080)
PORT=8080

# Log Level (debug, info, warn, error)
LOG_LEVEL=info
